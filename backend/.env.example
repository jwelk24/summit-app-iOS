# Plaid sandbox credentials — copy this file to .env and fill in values.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Products and country/language used when creating a link_token.
PLAID_PRODUCTS=transactions,investments,liabilities
PLAID_COUNTRY_CODES=US
PLAID_LANGUAGE=en

# Hosted Link redirect — the app intercepts this URL in its WKWebView.
# It does not need to resolve to a real web page; the scheme/host/path just
# need to match what the app's webview is watching for.
PLAID_REDIRECT_URI=https://summit.local/plaid-redirect

# Server bind
PORT=8080
